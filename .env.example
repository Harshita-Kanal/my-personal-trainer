# LLM provider: groq or openai. If omitted, Groq is used when VITE_GROQ_API_KEY is set.
VITE_LLM_PROVIDER="groq"

VITE_GROQ_API_KEY="your-groq-api-key-here"
VITE_GROQ_MODEL="llama-3.3-70b-versatile"

VITE_OPENAI_API_KEY="your-api-key-here"
VITE_OPENAI_MODEL="gpt-4o"

# Clerk auth (https://clerk.com) — enable "Email address + Password" and "Google"
# under User & Authentication in your Clerk dashboard.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your-publishable-key-here"
CLERK_SECRET_KEY="sk_test_your-secret-key-here"
# Comma-separated origins allowed to use this Clerk instance (dev + prod).
CLERK_AUTHORIZED_PARTIES="http://localhost:5173"
