{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build && cd server && npm install",
    "nixpacksPlan": {
      "variables": {
        "NIXPACKS_NODE_VERSION": "20"
      }
    }
  },
  "deploy": {
    "startCommand": "node server/index.js",
    "restartPolicyType": "ON_FAILURE"
  }
}
